# ─── LLM & Search APIs (required for AI research) ───────────────────────────
# Groq: https://console.groq.com/keys
# Used by LangGraph agent (src/lib/agent.ts) and help chat (/api/help-chat)
GROQ_API_KEY="gsk_..."

# Tavily: https://tavily.com/
# Used for news sentiment and competitor analysis nodes
TAVILY_API_KEY="tvly-..."

# ─── Supabase (required for auth and credit system) ─────────────────────────
# Create a project at https://supabase.com
# Run supabase_schema.sql in the SQL editor to set up profiles table
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR_PROJECT_ID].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ─── Optional ───────────────────────────────────────────────────────────────
# NODE_ENV is set automatically by Next.js (development / production)
# No additional env vars required for Yahoo Finance (no API key needed)
